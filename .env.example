# ═══════════════════════════════════════════════════════════════════
# AI STARTUP BUILDER — Environment Variables Reference
# Copy this file to .env.local and fill in your values.
# .env.example is committed to git. .env.local is NOT.
# ═══════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────
# SHARED — Required by all services
# ─────────────────────────────────────────────────────────────────
NODE_ENV=development                          # development | staging | production
LOG_LEVEL=debug                               # debug | info | warn | error

# ─────────────────────────────────────────────────────────────────
# DATABASE — PostgreSQL 16 (RDS in production)
# Local: started via docker-compose.yml
# ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:devpassword@localhost:5432/aistartup
DATABASE_READ_REPLICA_URL=postgresql://postgres:devpassword@localhost:5432/aistartup
# ^ In production, point to the RDS read replica endpoint for analytics-service

# ─────────────────────────────────────────────────────────────────
# REDIS — Redis 7 (ElastiCache in production)
# Local: started via docker-compose.yml
# ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://:devpassword@localhost:6379
# ^ Format: redis://[:password@]host:port[/db-number]

# ─────────────────────────────────────────────────────────────────
# JWT — RS256 asymmetric keys
# Generate locally: pnpm tsx scripts/dev/generate-keys.ts
# In production: store in AWS Secrets Manager, never in env files
# ─────────────────────────────────────────────────────────────────
JWT_PRIVATE_KEY_BASE64=                       # base64-encoded PKCS8 RSA private key (4096-bit)
JWT_PUBLIC_KEY_BASE64=                        # base64-encoded SPKI RSA public key
JWT_ACCESS_TOKEN_TTL=900                      # Access token lifetime: 15 minutes in seconds
JWT_REFRESH_TOKEN_TTL=604800                  # Refresh token lifetime: 7 days in seconds

# ─────────────────────────────────────────────────────────────────
# AUTH SERVICE (port 4001)
# Google OAuth: https://console.cloud.google.com/apis/credentials
# ─────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=                             # OAuth 2.0 Client ID from GCP Console
GOOGLE_CLIENT_SECRET=                         # OAuth 2.0 Client Secret from GCP Console
GOOGLE_REDIRECT_URI=http://localhost:4001/auth/oauth/google/callback
FRONTEND_APP_URL=http://localhost:3000        # Web app base URL (OAuth error redirects, deep links)
MFA_ENCRYPTION_KEY=                           # 64 hex chars (32 bytes) — generate with: openssl rand -hex 32

# ─────────────────────────────────────────────────────────────────
# AI SERVICE (port 4004)
# Primary LLM: Anthropic Claude — https://console.anthropic.com
# Embeddings: OpenAI — https://platform.openai.com (RAG only)
# ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                            # sk-ant-... — primary agent LLM (Claude Sonnet/Opus)
OPENAI_API_KEY=                               # sk-... — used for text-embedding-3-large ONLY

# ─────────────────────────────────────────────────────────────────
# RAG SERVICE (port 4005)
# Vector DB: Pinecone — https://app.pinecone.io
# WARNING: PINECONE_EMBEDDING_MODEL dimension is fixed at index creation.
#          Do NOT change this value after creating the index.
# ─────────────────────────────────────────────────────────────────
PINECONE_API_KEY=                             # From Pinecone dashboard → API Keys
PINECONE_INDEX_NAME=ai-startup-rag            # Index name — must match Pinecone dashboard
PINECONE_ENVIRONMENT=us-east-1-aws            # Cloud + region of your Pinecone index
PINECONE_EMBEDDING_MODEL=text-embedding-3-large  # DO NOT CHANGE — index dimension fixed at creation

# ─────────────────────────────────────────────────────────────────
# BILLING SERVICE (port 4006)
# Stripe: https://dashboard.stripe.com
# Webhook secret: Stripe Dashboard → Webhooks → your endpoint → Signing secret
# ─────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=                            # Stripe secret key from Dashboard (test vs live mode)
STRIPE_WEBHOOK_SECRET=                        # whsec_... — from Stripe webhook endpoint config
STRIPE_FREE_PLAN_PRICE_ID=                    # price_... — create a $0 price in Stripe dashboard
STRIPE_PRO_MONTHLY_PRICE_ID=                  # price_... — $29/month Pro plan
STRIPE_PRO_YEARLY_PRICE_ID=                   # price_... — $290/year Pro plan (annual discount)

# ─────────────────────────────────────────────────────────────────
# NOTIFICATION SERVICE (port 4007)
# Transactional email: Resend — https://resend.com
# ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=                               # re_... — from Resend dashboard → API Keys
RESEND_FROM_EMAIL=noreply@aistartupbuilder.com  # Must be from a verified domain in Resend

# ─────────────────────────────────────────────────────────────────
# AWS — Object storage (S3) and infrastructure
# Use IAM roles in production. Access keys are for local dev only.
# Never commit real keys. Rotate immediately if leaked.
# ─────────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=                            # IAM user with S3 read/write permissions (local only)
AWS_SECRET_ACCESS_KEY=                        # Corresponding secret key (local only)
AWS_S3_BUCKET_UPLOADS=ai-startup-user-uploads-dev    # Bucket for user-uploaded RAG documents
AWS_S3_BUCKET_EXPORTS=ai-startup-project-exports-dev # Bucket for project ZIP/DOCX exports

# ─────────────────────────────────────────────────────────────────
# PROJECT SERVICE (port 4003)
# Plan limits: enterprise uses unlimited (omit or set high); enforced in service
# ─────────────────────────────────────────────────────────────────
FREE_PLAN_PROJECT_LIMIT=3
PRO_PLAN_PROJECT_LIMIT=20

# ─────────────────────────────────────────────────────────────────
# USER SERVICE (port 4002)
# ─────────────────────────────────────────────────────────────────
API_KEY_HMAC_SECRET=                          # min 32 chars — generate with: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=                   # 64 hex chars (32 bytes) — openssl rand -hex 32

# ─────────────────────────────────────────────────────────────────
# FRONTEND — apps/web (Next.js, port 3000)
# NEXT_PUBLIC_ prefix required for browser-accessible variables
# ─────────────────────────────────────────────────────────────────
# Required: browser API base (api-gateway). Without this, requests hit localhost:3000 and break auth.
NEXT_PUBLIC_API_URL=http://localhost:4000     # API gateway — /auth/* proxies to services
NEXT_PUBLIC_APP_URL=http://localhost:3000     # Public-facing app URL (used in emails, redirects)
# Optional: comma-separated origins allowed to postMessage Google OAuth results (default dev allows :4001)
# NEXT_PUBLIC_OAUTH_MESSAGE_ORIGINS=http://localhost:4001

# ─────────────────────────────────────────────────────────────────
# ADMIN APP — apps/admin (Next.js, port 3002)
# ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:4000  # Same Kong gateway — admin routes use role checks
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002      # Admin app public URL
