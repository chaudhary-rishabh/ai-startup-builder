{
  "name": "ai-startup-builder",
  "private": true,
  "version": "0.0.1",
  "scripts": {
    "dev": "turbo run dev --concurrency 15",
    "predev": "pnpm run check-env -- --service all",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,json,md,yml,yaml}\"",
    "db:migrate": "dotenv -e .env.local -- turbo run db:migrate",
    "db:generate": "dotenv -e .env.local -- turbo run db:generate",
    "clean": "turbo run clean && rimraf node_modules",
    "prepare": "husky install",
    "generate-keys": "pnpm --filter @ai-startup-builder/scripts generate-keys",
    "seed": "dotenv -e .env.local -- pnpm --filter @ai-startup-builder/scripts seed",
    "reset-db": "pnpm --filter @ai-startup-builder/scripts reset-db",
    "check-env": "pnpm --filter @ai-startup-builder/scripts check-env"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.0.0",
    "knip": "^5.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.8.3",
    "rimraf": "^5.0.0",
    "turbo": "^2.9.9",
    "typescript": "^5.5.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.12.0"
}
