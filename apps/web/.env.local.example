# Required
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id
NEXT_PUBLIC_S3_BUCKET_HOSTNAME=your-bucket.s3.amazonaws.com

# JWT public key (same RS256 key as backends)
JWT_PUBLIC_KEY_BASE64=your_base64_encoded_rsa_public_key
