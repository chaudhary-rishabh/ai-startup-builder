{
  "name": "@ai-startup-builder/user-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "smoke:api-key": "tsx scripts/smoke-api-key.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.4.0",
    "@repo/db": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/validators": "workspace:*",
    "drizzle-orm": "^0.32.0",
    "hono": "^4.5.0",
    "ioredis": "^5.4.0",
    "jose": "^5.6.0",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.23.0",
    "ioredis-mock": "^8.9.0",
    "tsx": "^4.16.0",
    "typescript": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
