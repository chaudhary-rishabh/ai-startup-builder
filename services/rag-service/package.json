{
  "name": "@ai-startup-builder/rag-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@aws-sdk/s3-request-presigner": "^3.600.0",
    "@hono/node-server": "^1.12.0",
    "@pinecone-database/pinecone": "^3.0.0",
    "@repo/db": "workspace:*",
    "@repo/types": "workspace:*",
    "@google/generative-ai": "^0.24.1",
    "@repo/validators": "workspace:*",
    "bullmq": "^5.12.0",
    "cheerio": "^1.0.0",
    "cohere-ai": "^7.11.0",
    "drizzle-orm": "^0.32.0",
    "hono": "^4.5.0",
    "ioredis": "^5.4.0",
    "jose": "^5.6.0",
    "js-tiktoken": "^1.0.15",
    "mammoth": "^1.8.0",
    "pdfjs-dist": "^4.6.0",
    "pg": "^8.12.0",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^10.16.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.23.0",
    "ioredis-mock": "^8.9.0",
    "testcontainers": "^10.16.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
