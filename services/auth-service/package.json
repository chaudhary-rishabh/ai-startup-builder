{
  "name": "@ai-startup-builder/auth-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run --coverage && vitest run --config vitest.fullflow.config.ts",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.4.0",
    "@repo/db": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/validators": "workspace:*",
    "bcryptjs": "^2.4.3",
    "drizzle-orm": "^0.32.0",
    "hono": "^4.5.0",
    "ioredis": "^5.4.0",
    "jose": "^5.6.0",
    "otplib": "^12.0.1",
    "pg": "^8.12.0",
    "qrcode": "^1.5.4",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.14.0",
    "@testcontainers/redis": "^11.14.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/qrcode": "^1.5.5",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.23.0",
    "ioredis-mock": "^8.9.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
