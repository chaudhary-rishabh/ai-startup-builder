{
  "name": "@ai-startup-builder/billing-service",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:migrate": "drizzle-kit migrate",
    "db:generate": "drizzle-kit generate",
    "test": "vitest run --coverage",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@hono/node-server": "^1.12.0",
    "@hono/zod-validator": "^0.7.6",
    "@repo/db": "workspace:*",
    "@repo/types": "workspace:*",
    "@repo/validators": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.17",
    "ioredis": "^5.4.0",
    "jose": "^5.6.0",
    "pg": "^8.12.0",
    "razorpay": "^2.9.6",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "drizzle-kit": "^0.31.10",
    "ioredis-mock": "^8.9.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
